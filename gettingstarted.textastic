<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>IronCorps — U.S. Military Recruiting</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --black: #050608;
      --navy: #080e1a;
      --navy-mid: #0d1829;
      --navy-light: #111e33;
      --accent: #c8a850;
      --accent-dim: #8a6f2e;
      --white: #e8eaf0;
      --grey: #8a90a0;
      --grey-light: #b0b8c8;
      --red: #b02020;
      --green: #2a7a3a;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--black); color: var(--white); font-family: 'Barlow', sans-serif; overflow-x: hidden; cursor: default; }
    body::before { content:''; position:fixed; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events:none; z-index:9999; opacity:0.3; }

```
/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--navy); }
::-webkit-scrollbar-thumb { background: var(--accent); }

/* ── NAV ── */
nav { position:fixed; top:0; left:0; right:0; z-index:500; display:flex; align-items:center; justify-content:space-between; padding:1rem 3rem; background:rgba(5,6,8,0.97); border-bottom:1px solid rgba(200,168,80,0.15); }
.nav-logo { font-family:'Bebas Neue',sans-serif; font-size:1.6rem; letter-spacing:0.15em; color:var(--accent); text-decoration:none; }
.nav-logo span { color:var(--white); }
.nav-links { display:flex; gap:0; list-style:none; }
.nav-links a { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--grey); text-decoration:none; padding:0.5rem 1rem; transition:color 0.2s; }
.nav-links a:hover { color:var(--accent); }
.nav-cta { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--black); background:var(--accent); border:none; padding:0.65rem 1.5rem; cursor:pointer; transition:all 0.2s; }
.nav-cta:hover { background:#e0bf6a; }
.hamburger { display:none; flex-direction:column; gap:5px; cursor:pointer; }
.hamburger span { display:block; width:24px; height:2px; background:var(--white); transition:all 0.3s; }

/* ── HERO ── */
.hero { position:relative; min-height:100vh; display:flex; align-items:center; overflow:hidden; }
.hero-img { position:absolute; inset:0; background:url('https://images.unsplash.com/photo-1549927681-0b673b8243ab?w=1600&q=80') center/cover no-repeat; z-index:0; }
.hero-img::after { content:''; position:absolute; inset:0; background:linear-gradient(to right, rgba(5,6,8,0.95) 45%, rgba(5,6,8,0.5) 100%); }
.hero-content { position:relative; z-index:2; padding:0 4rem 0 6rem; max-width:850px; }
.hero-label { display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; opacity:0; animation:fadeUp 0.6s ease 0.3s forwards; }
.hero-label::before { content:''; display:block; width:2.5rem; height:2px; background:var(--accent); }
.hero-label span { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.75rem; letter-spacing:0.35em; text-transform:uppercase; color:var(--accent); }
.hero h1 { font-family:'Bebas Neue',sans-serif; font-size:clamp(4rem,9vw,9rem); line-height:0.92; letter-spacing:0.02em; opacity:0; animation:fadeUp 0.7s ease 0.5s forwards; }
.hero h1 .gold { color:var(--accent); }
.hero h1 .outline { -webkit-text-stroke:1px rgba(200,168,80,0.6); color:transparent; }
.hero-sub { margin-top:2rem; font-size:1.05rem; font-weight:300; line-height:1.7; color:var(--grey-light); max-width:520px; border-left:2px solid var(--accent); padding-left:1.2rem; opacity:0; animation:fadeUp 0.7s ease 0.75s forwards; }
.hero-actions { margin-top:2.5rem; display:flex; gap:1rem; flex-wrap:wrap; opacity:0; animation:fadeUp 0.7s ease 0.95s forwards; }
.hero-stats { position:absolute; bottom:2.5rem; left:6rem; display:flex; gap:3.5rem; z-index:2; opacity:0; animation:fadeUp 0.7s ease 1.2s forwards; }
.stat-num { font-family:'Bebas Neue',sans-serif; font-size:2.5rem; color:var(--accent); line-height:1; }
.stat-label { font-family:'Barlow Condensed',sans-serif; font-size:0.68rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--grey); margin-top:0.2rem; }

/* ── BUTTONS ── */
.btn-primary { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.82rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--black); background:var(--accent); border:none; padding:0.95rem 2.2rem; cursor:pointer; transition:all 0.2s; text-decoration:none; display:inline-block; }
.btn-primary:hover { background:#e0bf6a; transform:translateY(-2px); box-shadow:0 8px 25px rgba(200,168,80,0.3); }
.btn-outline { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.82rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--white); background:transparent; border:1px solid rgba(255,255,255,0.3); padding:0.95rem 2.2rem; cursor:pointer; text-decoration:none; display:inline-block; transition:all 0.2s; }
.btn-outline:hover { border-color:var(--accent); color:var(--accent); }

/* ── TICKER ── */
.ticker { background:var(--accent); padding:0.6rem 0; overflow:hidden; white-space:nowrap; }
.ticker-track { display:inline-flex; animation:ticker 35s linear infinite; }
.ticker-item { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.72rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--black); padding:0 3rem; }
.ticker-item::after { content:'◆'; margin-left:3rem; }

/* ── SECTION BASE ── */
.section-label { display:flex; align-items:center; gap:1rem; margin-bottom:1rem; }
.section-label::before { content:''; display:block; width:2rem; height:2px; background:var(--accent); }
.section-label span { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.7rem; letter-spacing:0.35em; text-transform:uppercase; color:var(--accent); }
.section-heading { font-family:'Bebas Neue',sans-serif; font-size:clamp(2.5rem,4.5vw,4.5rem); line-height:0.95; letter-spacing:0.02em; }
.section-heading span { color:var(--accent); }
section { padding:6rem 6rem; }

/* ── WHY JOIN ── */
.why { background:var(--navy); }
.why-intro { max-width:600px; }
.why-body { margin-top:1rem; font-size:1rem; font-weight:300; line-height:1.8; color:var(--grey-light); }
.benefits-grid { margin-top:4rem; display:grid; grid-template-columns:repeat(3,1fr); gap:2px; background:rgba(200,168,80,0.1); }
.benefit-card { background:var(--navy-mid); padding:2.5rem 2rem; position:relative; overflow:hidden; transition:background 0.3s; }
.benefit-card::after { content:''; position:absolute; bottom:0; left:0; width:0; height:3px; background:var(--accent); transition:width 0.4s; }
.benefit-card:hover { background:var(--navy-light); }
.benefit-card:hover::after { width:100%; }
.benefit-icon { font-size:2.2rem; margin-bottom:1rem; }
.benefit-title { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.1rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent); margin-bottom:0.6rem; }
.benefit-desc { font-size:0.9rem; line-height:1.7; color:var(--grey-light); }
.benefit-tag { display:inline-block; margin-top:0.8rem; font-family:'Barlow Condensed',sans-serif; font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--accent); border:1px solid var(--accent-dim); padding:0.2rem 0.6rem; }

/* ── IMAGE GALLERY STRIP ── */
.gallery-strip { padding:0; display:grid; grid-template-columns:repeat(4,1fr); height:320px; }
.gallery-img { position:relative; overflow:hidden; }
.gallery-img img { width:100%; height:100%; object-fit:cover; transition:transform 0.6s; filter:grayscale(30%) brightness(0.7); }
.gallery-img:hover img { transform:scale(1.08); filter:grayscale(0%) brightness(0.85); }
.gallery-img-label { position:absolute; bottom:0; left:0; right:0; padding:1rem; background:linear-gradient(to top,rgba(5,6,8,0.9),transparent); font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--accent); }

/* ── APPLICATION PROCESS ── */
.process { background:var(--black); }
.process-steps { margin-top:4rem; display:grid; grid-template-columns:repeat(5,1fr); gap:0; position:relative; }
.process-steps::before { content:''; position:absolute; top:2.5rem; left:10%; right:10%; height:1px; background:linear-gradient(to right,transparent,var(--accent),transparent); z-index:0; }
.step { display:flex; flex-direction:column; align-items:center; text-align:center; padding:0 1rem; position:relative; z-index:1; }
.step-num { width:5rem; height:5rem; border:1px solid var(--accent); display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:1.8rem; color:var(--accent); background:var(--black); margin-bottom:1.5rem; position:relative; }
.step-num::after { content:''; position:absolute; inset:-4px; border:1px solid rgba(200,168,80,0.2); }
.step-title { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.9rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--white); margin-bottom:0.5rem; }
.step-desc { font-size:0.8rem; line-height:1.6; color:var(--grey); }

/* ── APPLICATION FORM ── */
.apply-section { background:var(--navy); }
.apply-grid { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:start; margin-top:3rem; }
.apply-info h3 { font-family:'Bebas Neue',sans-serif; font-size:2rem; color:var(--accent); margin-bottom:1rem; letter-spacing:0.05em; }
.apply-info p { font-size:0.95rem; line-height:1.8; color:var(--grey-light); margin-bottom:1.5rem; }
.apply-checklist { list-style:none; display:flex; flex-direction:column; gap:0.75rem; }
.apply-checklist li { display:flex; align-items:center; gap:0.75rem; font-family:'Barlow Condensed',sans-serif; font-size:0.95rem; letter-spacing:0.05em; color:var(--grey-light); }
.apply-checklist li::before { content:'✓'; color:var(--accent); font-weight:700; font-size:1rem; }
.apply-form { display:flex; flex-direction:column; gap:1.2rem; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.form-group { display:flex; flex-direction:column; gap:0.4rem; }
.form-group label { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.72rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--grey); }
.form-group input, .form-group select, .form-group textarea {
  background:rgba(255,255,255,0.05); border:1px solid rgba(200,168,80,0.2); color:var(--white);
  padding:0.75rem 1rem; font-family:'Barlow',sans-serif; font-size:0.9rem;
  outline:none; transition:border-color 0.2s; width:100%;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color:var(--accent); background:rgba(200,168,80,0.05); }
.form-group select option { background:var(--navy-mid); color:var(--white); }
.form-group textarea { resize:vertical; min-height:100px; }
.form-submit { background:var(--accent); color:var(--black); border:none; padding:1rem 2rem; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; cursor:pointer; transition:all 0.2s; width:100%; }
.form-submit:hover { background:#e0bf6a; }
.form-note { font-size:0.78rem; color:var(--grey); text-align:center; line-height:1.5; }
.form-success { display:none; background:rgba(42,122,58,0.15); border:1px solid var(--green); padding:1.5rem; text-align:center; }
.form-success h4 { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; color:var(--accent); letter-spacing:0.05em; }
.form-success p { font-size:0.9rem; color:var(--grey-light); margin-top:0.5rem; }

/* ── CITIZENSHIP / GREEN CARD ── */
.citizenship { background:var(--black); }
.citizenship-grid { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; margin-top:3rem; }
.citizenship-img { position:relative; height:500px; overflow:hidden; }
.citizenship-img img { width:100%; height:100%; object-fit:cover; filter:brightness(0.7); }
.citizenship-img::after { content:''; position:absolute; inset:0; border:1px solid rgba(200,168,80,0.2); pointer-events:none; }
.citizenship-img-label { position:absolute; bottom:1.5rem; left:1.5rem; font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--accent); }
.citizenship-content p { font-size:0.95rem; line-height:1.8; color:var(--grey-light); margin-bottom:1.5rem; }
.citizenship-path { background:var(--navy-mid); border-left:3px solid var(--accent); padding:1.5rem; margin:1.5rem 0; }
.citizenship-path h4 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.9rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--accent); margin-bottom:0.5rem; }
.citizenship-path p { font-size:0.88rem; color:var(--grey-light); margin:0; line-height:1.7; }
.citizenship-note { font-size:0.8rem; color:var(--grey); border:1px solid rgba(200,168,80,0.15); padding:1rem; line-height:1.6; }
.citizenship-note strong { color:var(--accent); }

/* ── NEWS ── */
.news { background:var(--navy); }
.news-grid { margin-top:3rem; display:grid; grid-template-columns:2fr 1fr; gap:2px; background:rgba(200,168,80,0.1); }
.news-featured { position:relative; overflow:hidden; min-height:420px; }
.news-featured img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; filter:brightness(0.5); transition:transform 0.6s; }
.news-featured:hover img { transform:scale(1.05); }
.news-featured-content { position:absolute; bottom:0; left:0; right:0; padding:2.5rem; background:linear-gradient(to top,rgba(5,6,8,0.95),transparent); }
.news-tag { display:inline-block; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.65rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--black); background:var(--accent); padding:0.25rem 0.6rem; margin-bottom:0.75rem; }
.news-featured-title { font-family:'Bebas Neue',sans-serif; font-size:2rem; letter-spacing:0.03em; line-height:1.1; color:var(--white); }
.news-featured-meta { font-family:'Barlow Condensed',sans-serif; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--grey); margin-top:0.5rem; }
.news-sidebar { display:flex; flex-direction:column; gap:2px; background:rgba(200,168,80,0.1); }
.news-card { background:var(--navy-mid); padding:1.5rem; display:flex; gap:1rem; cursor:pointer; transition:background 0.2s; }
.news-card:hover { background:var(--navy-light); }
.news-card-img { width:80px; height:80px; object-fit:cover; flex-shrink:0; filter:grayscale(30%); }
.news-card-body {}
.news-card-tag { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--accent); }
.news-card-title { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.9rem; line-height:1.3; color:var(--white); margin-top:0.3rem; }
.news-card-date { font-size:0.75rem; color:var(--grey); margin-top:0.4rem; }

/* ── TESTIMONIALS ── */
.testimonials { background:var(--black); }
.testimonials-grid { margin-top:3rem; display:grid; grid-template-columns:repeat(3,1fr); gap:2px; background:rgba(200,168,80,0.1); }
.testimonial { background:var(--navy); padding:2.5rem 2rem; position:relative; }
.testimonial::before { content:'"'; font-family:'Bebas Neue',sans-serif; font-size:6rem; color:rgba(200,168,80,0.1); position:absolute; top:1rem; right:1.5rem; line-height:1; }
.testimonial-text { font-size:0.95rem; line-height:1.8; color:var(--grey-light); font-style:italic; margin-bottom:1.5rem; position:relative; z-index:1; }
.testimonial-author { display:flex; align-items:center; gap:1rem; }
.testimonial-avatar { width:48px; height:48px; border-radius:50%; object-fit:cover; border:2px solid var(--accent); filter:grayscale(20%); }
.testimonial-name { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.9rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--white); }
.testimonial-rank { font-size:0.78rem; color:var(--accent); }

/* ── CONTACT ── */
.contact-section { background:var(--navy-mid); }
.contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:5rem; margin-top:3rem; }
.contact-info h3 { font-family:'Bebas Neue',sans-serif; font-size:2rem; color:var(--accent); letter-spacing:0.05em; margin-bottom:1rem; }
.contact-info p { font-size:0.95rem; line-height:1.8; color:var(--grey-light); margin-bottom:2rem; }
.contact-detail { display:flex; align-items:flex-start; gap:1rem; margin-bottom:1.5rem; }
.contact-detail-icon { font-size:1.5rem; }
.contact-detail-text label { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--accent); display:block; margin-bottom:0.2rem; }
.contact-detail-text p { font-size:0.9rem; color:var(--grey-light); margin:0; line-height:1.5; }
.contact-form { display:flex; flex-direction:column; gap:1.2rem; }

/* ── FOOTER ── */
footer { background:var(--black); border-top:1px solid rgba(200,168,80,0.1); }
.footer-top { padding:4rem 6rem; display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:3rem; }
.footer-brand { }
.footer-logo { font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:0.15em; color:var(--accent); display:block; margin-bottom:1rem; text-decoration:none; }
.footer-logo span { color:var(--white); }
.footer-desc { font-size:0.88rem; line-height:1.7; color:var(--grey); max-width:280px; }
.footer-col h4 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--accent); margin-bottom:1.2rem; }
.footer-col ul { list-style:none; display:flex; flex-direction:column; gap:0.6rem; }
.footer-col ul a { font-size:0.88rem; color:var(--grey); text-decoration:none; transition:color 0.2s; }
.footer-col ul a:hover { color:var(--accent); }
.footer-bottom { padding:1.2rem 6rem; border-top:1px solid rgba(255,255,255,0.05); display:flex; justify-content:space-between; align-items:center; }
.footer-bottom p { font-family:'Barlow Condensed',sans-serif; font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--grey); }

/* ── MOBILE NAV ── */
.mobile-menu { display:none; position:fixed; inset:0; background:rgba(5,6,8,0.98); z-index:400; flex-direction:column; align-items:center; justify-content:center; gap:2rem; }
.mobile-menu.open { display:flex; }
.mobile-menu a { font-family:'Bebas Neue',sans-serif; font-size:2.5rem; letter-spacing:0.1em; color:var(--white); text-decoration:none; }
.mobile-menu a:hover { color:var(--accent); }

/* ── ANIMATIONS ── */
@keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
@keyframes fadeIn { from{opacity:0} to{opacity:1} }
@keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

/* ── RESPONSIVE ── */
@media(max-width:1000px){
  section{padding:4rem 2rem;}
  .hero-content{padding:0 2rem 0 2.5rem;}
  .hero-stats{left:2.5rem;gap:2rem;}
  nav{padding:1rem 1.5rem;}
  .nav-links{display:none;}
  .hamburger{display:flex;}
  .benefits-grid{grid-template-columns:1fr 1fr;}
  .gallery-strip{grid-template-columns:1fr 1fr;height:auto;}
  .gallery-img{height:200px;}
  .process-steps{grid-template-columns:1fr 1fr;gap:2rem;}
  .process-steps::before{display:none;}
  .apply-grid,.citizenship-grid,.contact-grid{grid-template-columns:1fr;}
  .news-grid{grid-template-columns:1fr;}
  .testimonials-grid{grid-template-columns:1fr;}
  .footer-top{grid-template-columns:1fr 1fr;padding:3rem 2rem;}
  .footer-bottom{padding:1.2rem 2rem;flex-direction:column;gap:0.5rem;text-align:center;}
  .form-row{grid-template-columns:1fr;}
}
@media(max-width:600px){
  .benefits-grid{grid-template-columns:1fr;}
  .hero h1{font-size:4rem;}
}
```

  </style>
</head>
<body>

<!-- MOBILE MENU -->

<div class="mobile-menu" id="mobileMenu">
  <a href="#why" onclick="closeMobile()">Why Join</a>
  <a href="#process" onclick="closeMobile()">Apply</a>
  <a href="#citizenship" onclick="closeMobile()">Citizenship</a>
  <a href="#news" onclick="closeMobile()">News</a>
  <a href="#contact" onclick="closeMobile()">Contact</a>
  <a href="#apply-form" class="btn-primary" onclick="closeMobile()" style="margin-top:1rem;">Enlist Now</a>
</div>

