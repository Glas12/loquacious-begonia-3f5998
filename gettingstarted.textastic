<!-- TESTIMONIALS -->

<section class="testimonials" id="testimonials">
  <div class="section-label"><span>Those Who Served</span></div>
  <h2 class="section-heading">VOICES FROM<br><span>THE FIELD</span></h2>
  <div class="testimonials-grid">
    <div class="testimonial">
      <p class="testimonial-text">Joining the Army was the best decision of my life. I came in with nothing and left with a degree, a pension, and skills no college could have taught me. I am who I am because of this uniform.</p>
      <div class="testimonial-author">
        <img class="testimonial-avatar" src="https://images.unsplash.com/photo-1521119989659-a83eee488004?w=100&q=80" alt="Sgt. Marcus"/>
        <div>
          <div class="testimonial-name">Sgt. Marcus T.</div>
          <div class="testimonial-rank">U.S. Army · 8 Years Served</div>
        </div>
      </div>
    </div>
    <div class="testimonial">
      <p class="testimonial-text">As an immigrant, military service gave me the chance to earn my citizenship while giving back to the country that gave me a future. I'm proud to call myself an American Marine.</p>
      <div class="testimonial-author">
        <img class="testimonial-avatar" src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=100&q=80" alt="Cpl. Reyes"/>
        <div>
          <div class="testimonial-name">Cpl. Diego R.</div>
          <div class="testimonial-rank">U.S. Marines · Naturalized Citizen</div>
        </div>
      </div>
    </div>
    <div class="testimonial">
      <p class="testimonial-text">The Navy paid for my entire nursing degree and I served as a combat nurse. When I transitioned out, hospitals were lining up to hire me. Military service opens doors civilians can't even see.</p>
      <div class="testimonial-author">
        <img class="testimonial-avatar" src="https://images.unsplash.com/photo-1494790108755-2616b612b47c?w=100&q=80" alt="Petty Officer Chen"/>
        <div>
          <div class="testimonial-name">PO2 Sarah C.</div>
          <div class="testimonial-rank">U.S. Navy · Medical Corps</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->

<section class="contact-section" id="contact">
  <div class="section-label"><span>Get In Touch</span></div>
  <h2 class="section-heading">SPEAK WITH A<br><span>RECRUITER</span></h2>
  <div class="contact-grid">
    <div class="contact-info">
      <h3>We're Here For You</h3>
      <p>Have questions before you apply? Our recruiters are available to answer everything — no pressure, no commitment. Just honest information about your options.</p>
      <div class="contact-detail">
        <div class="contact-detail-icon">📞</div>
        <div class="contact-detail-text">
          <label>Recruiting Hotline</label>
          <p>1-800-USA-ARMY (1-800-872-2769)</p>
        </div>
      </div>
      <div class="contact-detail">
        <div class="contact-detail-icon">✉️</div>
        <div class="contact-detail-text">
          <label>Email</label>
          <p>recruiting@ironcorps.mil</p>
        </div>
      </div>
      <div class="contact-detail">
        <div class="contact-detail-icon">🕐</div>
        <div class="contact-detail-text">
          <label>Hours</label>
          <p>Monday – Friday: 8:00 AM – 6:00 PM<br/>Saturday: 9:00 AM – 2:00 PM</p>
        </div>
      </div>
      <div class="contact-detail">
        <div class="contact-detail-icon">📍</div>
        <div class="contact-detail-text">
          <label>Find a Recruiter Near You</label>
          <p>Visit <strong style="color:var(--accent)">goarmy.com/locate-a-recruiter</strong> to find your nearest recruiting office.</p>
        </div>
      </div>
    </div>
    <form class="contact-form" onsubmit="submitContact(event)">
      <div class="form-group">
        <label>Your Name *</label>
        <input type="text" placeholder="Full Name" required/>
      </div>
      <div class="form-group">
        <label>Email *</label>
        <input type="email" placeholder="you@example.com" required/>
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="tel" placeholder="(555) 000-0000"/>
      </div>
      <div class="form-group">
        <label>Subject</label>
        <select>
          <option>General Inquiry</option>
          <option>Enlistment Requirements</option>
          <option>Education Benefits</option>
          <option>Citizenship / Immigration</option>
          <option>Career Fields / MOS</option>
          <option>Officer Programs</option>
        </select>
      </div>
      <div class="form-group">
        <label>Message *</label>
        <textarea placeholder="Ask your recruiter anything..." required></textarea>
      </div>
      <button type="submit" class="form-submit" id="contactBtn">Send Message →</button>
    </form>
  </div>
</section>

